# ── App ────────────────────────────────────────────────────────────────────────
CACHE_DIR=.cache

# ── Cuemath LLM gateway (AI Expert Review synthesis) ──────────────────────────
# LiteLLM proxy fronting Bedrock; Anthropic-shaped /v1/messages, virtual-key auth.
LLM_GATEWAY_BASE_URL=https://llm-gateway.cuemath.com
LLM_API_KEY=
# Model alias the gateway exposes (e.g. claude-sonnet-4-6 / claude-opus-4-7 / claude-haiku-4-5)
LLM_MODEL=claude-sonnet-4-6

# ── Cuemath data gateway (Learnosity item content) ────────────────────────────
# Full gateway resources endpoint, e.g. https://<host>/api/go/data/v1/resources
DATA_GATEWAY_BASE_URL=
DATA_GATEWAY_TOKEN=
# Optional — Learnosity request-signing domain (defaults to leap.cuemath.com)
LEARNOSITY_MS_DOMAIN_URL=leap.cuemath.com
